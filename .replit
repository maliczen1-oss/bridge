modules = ["nodejs-24", "python-3.12"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "WealthBuilder Bridge"

[[workflows.workflow]]
name = "WealthBuilder Bridge"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m bridge"
waitForPort = 8000

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
API_VERSION = "v1"
ENVIRONMENT = "development"
LOG_LEVEL = "INFO"
REQUEST_TIMEOUT = "30"
HOST = "0.0.0.0"
PORT = "8000"

[nix]
channel = "stable-25_05"
packages = ["libxcrypt"]
